rules_version = '2';

// Toda a leitura/escrita do app passa pelo servidor Next.js via Admin SDK,
// que ignora estas regras de segurança. O client SDK do Firebase só é usado
// para autenticação (signInWithEmailAndPassword), não para acessar o Firestore
// diretamente — por isso o acesso direto fica bloqueado por padrão.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
