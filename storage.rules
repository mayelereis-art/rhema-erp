rules_version = '2';

// Fotos de produtos precisam aparecer em contratos impressos e na loja
// pública (sem login) — por isso leitura é liberada. Upload só por usuário
// autenticado (equipe da Rhema), feito pelo client SDK no Catálogo.
service firebase.storage {
  match /b/{bucket}/o {
    match /produtos/{arquivo} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
