# Firebase (projeto em https://console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_API_KEY="..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="seu-projeto.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="seu-projeto"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="seu-projeto.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="..."
NEXT_PUBLIC_FIREBASE_APP_ID="..."

# Service account para o Admin SDK (uso em servidor/seed). Gere em:
# Configurações do projeto > Contas de serviço > Gerar nova chave privada.
# Cole o conteúdo do JSON inteiro em uma única linha.
# Em produção no Firebase App Hosting isso é resolvido automaticamente —
# só é necessário em desenvolvimento local.
FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'

# WhatsApp da Rhema (com DDI+DDD, só números) — usado nos botões "Quero este" da loja virtual.
NEXT_PUBLIC_WHATSAPP_NUMERO="5511998123344"
